# Database
DATABASE_URL="postgresql://yap:yap@localhost:5432/yap?schema=public"

# API
PORT=3333
NODE_ENV=development

# Auth (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET="change-me-in-production"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# Email
EMAIL_TRANSPORT=console
RESEND_API_KEY=""
MAIL_FROM="Yap <onboarding@resend.dev>"
# Email of the sole admin account (seeded as isAdmin; receives access-request notices)
ADMIN_EMAIL=""

# Web origin (CORS + cookie SameSite)
WEB_ORIGIN="http://localhost:3000"

SENTRY_DSN=""

# Avatar / file storage
# local = write to apps/api/uploads and serve at /uploads (dev default)
# r2    = upload to Cloudflare R2 (requires the R2_* vars below)
STORAGE_DRIVER=local
# Absolute base URL of this API, used to build local upload URLs
PUBLIC_API_URL="http://localhost:3333"

# Giphy GIF picker (create an "API" app at https://developers.giphy.com/dashboard)
# Both required only when using the GIF picker.
GIPHY_API_KEY=""
# HMAC secret for signing GIF proxy URLs. Generate like the JWT secret above.
# Keep stable: rotating it breaks proxy links in already-sent GIF messages.
GIF_PROXY_SECRET=""

# Cloudflare R2 (only needed when STORAGE_DRIVER=r2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Public base URL for the bucket (r2.dev URL or your custom domain), no trailing slash
R2_PUBLIC_URL=""
